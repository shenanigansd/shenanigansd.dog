---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPostPath, getPostStamp, sortPostsByDate } from "@/utils/posts";

const pageTitle = "shenanigans.dog";
const githubUrl = "https://github.com/shenanigansd";

const latestPosts = sortPostsByDate(await getCollection("blog")).slice(0, 2);
---

<BaseLayout pageTitle={pageTitle} wide>
    <div class="home">
        <div class="left">
            <div class="hello">// Bradley Reynolds · DevOps Engineer</div>
            <h1>Hey, I'm Bradley.</h1>
            <p>
                I'm a DevOps engineer who likes boring, reliable
                infrastructure — <span class="lk">Kubernetes</span>,
                infrastructure-as-code, and a <span class="lk">homelab</span>
                that has gotten slightly out of hand. I write about what I
                break and fix along the way.
            </p>
            <p class="sub">
                A random internet dog just trying to help. Mostly found as
                @shenanigansd.
            </p>
        </div>
        <div class="aside">
            <div class="stack">
                <div>
                    <div class="lbl"># now</div>
                    <div class="nowrow">
                        <span class="k">building</span>
                        <span class="v">Rebuilding the homelab on NixOS.</span>
                    </div>
                    <div class="nowrow">
                        <span class="k">learning</span>
                        <span class="v">Rust, slowly.</span>
                    </div>
                    <a class="seeall" href="/now">what I'm up to →</a>
                </div>
                <div id="latest">
                    <div class="lbl"># latest</div>
                    {
                        latestPosts.length > 0 ? (
                            latestPosts.map((post) => (
                                <a class="post" href={getPostPath(post)}>
                                    <div class="d">{getPostStamp(post)}</div>
                                    <div class="t">{post.data.title}</div>
                                </a>
                            ))
                        ) : (
                            <div class="nowrow">
                                <span class="v">No posts yet.</span>
                            </div>
                        )
                    }
                    <a class="seeall" href="/posts">all posts →</a>
                </div>
                <div>
                    <div class="lbl"># elsewhere</div>
                    <a
                        class="gh"
                        href={githubUrl}
                        aria-label="GitHub"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <svg viewBox="0 0 16 16" fill="currentColor"
                            ><path
                                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
                            ></path></svg
                        >
                    </a>
                </div>
            </div>
        </div>
    </div>
</BaseLayout>

<style>
    .home {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 300px;
        gap: 64px;
        padding: 32px 0 48px;
        align-content: center;
    }

    .left {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .hello {
        font-family: var(--font-monospace);
        font-size: 13px;
        color: var(--accent);
        margin-bottom: 18px;
    }
    .left h1 {
        font-size: 44px;
        font-weight: 700;
        letter-spacing: -0.7px;
        line-height: 1.1;
        color: var(--strong);
        margin-bottom: 22px;
    }
    .left p {
        margin-bottom: 16px;
        color: var(--foreground);
        max-width: 54ch;
    }
    .left p.sub {
        font-size: 15px;
        color: var(--dim);
        margin-bottom: 0;
    }
    .lk {
        color: var(--accent);
        border-bottom: 1px solid
            color-mix(in oklch, var(--accent), transparent 60%);
    }

    .aside {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .stack {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }
    .lbl {
        font-family: var(--font-monospace);
        font-size: 11.5px;
        letter-spacing: 0.069em;
        text-transform: uppercase;
        color: var(--dim);
        margin-bottom: 15px;
    }

    .nowrow {
        display: flex;
        gap: 14px;
        padding: 6px 0;
    }
    .nowrow .k {
        flex: none;
        width: 66px;
        padding-top: 2px;
        font-family: var(--font-monospace);
        font-size: 12px;
        color: var(--accent);
    }
    .nowrow .v {
        font-size: 14.5px;
        color: var(--foreground);
    }

    .seeall {
        display: inline-block;
        margin-top: 12px;
        font-family: var(--font-monospace);
        font-size: 12px;
        color: var(--accent);
    }
    .seeall:hover {
        text-decoration: underline;
    }

    .post {
        display: block;
        padding: 12px 0;
        border-top: 1px solid var(--border);
    }
    .post .d {
        font-family: var(--font-monospace);
        font-size: 11.5px;
        color: var(--dim);
    }
    .post .t {
        margin-top: 3px;
        font-size: 14.5px;
        line-height: 1.4;
        color: var(--foreground);
        transition: color 0.12s;
    }
    .post:hover .t {
        color: var(--strong);
    }

    .gh {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border: 1px solid var(--border-strong);
        border-radius: 10px;
        background: var(--panel-raised);
        color: var(--dim);
        transition:
            color 0.12s,
            border-color 0.12s;
    }
    .gh:hover {
        color: var(--strong);
        border-color: var(--accent);
    }
    .gh svg {
        width: 21px;
        height: 21px;
        display: block;
    }

    @media (max-width: 720px) {
        .home {
            grid-template-columns: 1fr;
            gap: 40px;
            padding: 24px 0 32px;
        }
        .left h1 {
            font-size: 34px;
        }
    }
</style>
